# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/

# Production builds
build/
dist/

# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/

# OS and IDE junk
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Security / Environment files
.env*
*.pem

# Next.js / TypeScript
*.tsbuildinfo
next-env.d.ts

# Backend Runtime Storage (ignore dynamic files, keep directories if needed)
backend/storage/uploads/*
!backend/storage/uploads/.gitkeep
backend/storage/references/*
!backend/storage/references/.gitkeep
backend/storage/results/*
!backend/storage/results/.gitkeep
backend/storage/thumbnails/*
!backend/storage/thumbnails/.gitkeep
